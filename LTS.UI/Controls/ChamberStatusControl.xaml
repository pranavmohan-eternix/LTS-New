<UserControl x:Class="LTS.UI.Controls.ChamberStatusControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Width="240"
            Height="240"
            Margin="10"
            Padding="15"
            Background="White"
            BorderBrush="#D9D9D9"
            BorderThickness="1"
            CornerRadius="10">

        <StackPanel>

            <!-- Header -->
            <Grid Margin="0,0,0,20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding Identifier}"
                           FontSize="24"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <Ellipse Grid.Column="1"
                         Width="18"
                         Height="18"
                         Fill="{Binding ProcessStateBrush}"
                         VerticalAlignment="Center"/>
            </Grid>

            <!-- Process State -->
            <TextBlock Text="State"
                       FontSize="14"
                       Foreground="Gray"/>

            <TextBlock Text="{Binding ProcessState}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,15"/>

            <!-- Material -->
            <TextBlock Text="Material"
                       FontSize="14"
                       Foreground="Gray"/>

            <TextBlock Text="{Binding MaterialPresence}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,15"/>

            <!-- Duration -->
            <TextBlock Text="Duration"
                       FontSize="14"
                       Foreground="Gray"/>

            <TextBlock Text="{Binding ProcessDuration}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,15"/>

            <!-- Recipe -->
            <TextBlock Text="Recipe"
                       FontSize="14"
                       Foreground="Gray"/>

            <TextBlock Text="{Binding SelectedRecipe}"
                       FontSize="16"
                       FontWeight="SemiBold"/>

        </StackPanel>

    </Border>

</UserControl>