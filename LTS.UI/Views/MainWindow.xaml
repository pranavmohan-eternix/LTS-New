<Window
    x:Class="LTS.UI.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="LTS"
    WindowState="Maximized">

    <Border Margin="15"
            BorderBrush="Black"
            BorderThickness="2">

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Navigation -->
            <StackPanel Grid.Column="0"
                        Margin="10">
                <Button x:Name="BtnJobs"
                            Content="Jobs"
                            Height="45"
                            Margin="0,0,0,15"
                            Click="BtnJobs_Click"/>

                <Button x:Name="BtnManual"
                            Content="Manual"
                            Height="45"
                            Click="BtnManual_Click"/>

            </StackPanel>

            <!-- Right Screen Area -->
            <Border Grid.Column="1"
                    Margin="10"
                    BorderBrush="Black"
                    BorderThickness="2">

                <ContentControl x:Name="MainContent"/>

            </Border>

        </Grid>

    </Border>

</Window>