<UserControl x:Class="LTS.UI.Views.ManualScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:LTS.UI.ViewModels"
             xmlns:views="clr-namespace:LTS.UI.Views">

    <UserControl.Resources>

        <DataTemplate DataType="{x:Type viewModels:ChamberViewModel}">
            <views:ChamberManualControl/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:LoadPortViewModel}">
            <views:LoadPortManualControl/>
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:TransferSystemViewModel}">
            <views:TransferSystemManualControl/>
        </DataTemplate>

    </UserControl.Resources>

    <Grid Margin="15">

        <Grid.ColumnDefinitions>

            <ColumnDefinition Width="180"/>

            <ColumnDefinition Width="*"/>

        </Grid.ColumnDefinitions>

        <!-- Equipment -->

        <GroupBox Header="Equipment"
                  Margin="5">

            <ListBox ItemsSource="{Binding EquipmentItems}"
                     SelectedItem="{Binding SelectedItem}"
                     DisplayMemberPath="Identifier"/>

        </GroupBox>

        <!-- Dynamic Manual Area -->

        <ContentControl Grid.Column="1"
                        Margin="5"
                        Content="{Binding SelectedItem}"/>

    </Grid>

</UserControl>