<UserControl x:Class="LTS.UI.Views.LoadPortManualControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>

        <Style TargetType="Button">

            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>

            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#D1D5DB"/>
                    <Setter Property="Foreground" Value="#6B7280"/>
                </Trigger>
            </Style.Triggers>

        </Style>

    </UserControl.Resources>

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.8*"/>
            <ColumnDefinition Width="1.4*"/>
        </Grid.ColumnDefinitions>
        <!-- Commands -->

        <GroupBox Header="Commands"
                  Grid.Column="0"
                  Margin="5">

            <StackPanel Margin="15">

                <Button Content="Load Carrier"
                        Click="BtnLoad_Click"
                        IsEnabled="{Binding CanLoad}"/>

                <Button Content="Unload Carrier"
                        Click="BtnUnload_Click"
                        IsEnabled="{Binding CanUnload}"/>

                <Button Content="Map Carrier"
                        Click="BtnMap_Click"
                        IsEnabled="{Binding CanMap}"/>

            </StackPanel>

        </GroupBox>

        <!-- Status -->

        <GroupBox Header="Status"
                  Grid.Column="1"
                  Margin="5">

            <Grid Margin="25">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="45"/>
                </Grid.RowDefinitions>
                <!-- Load Port -->

                <TextBlock Text="Load Port"
                           FontWeight="Bold"
                           FontSize="18"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding Identifier}"
                           FontSize="18"
                           VerticalAlignment="Center"/>

                <!-- Carrier -->

                <TextBlock Grid.Row="1"
                           Text="Carrier"
                           FontWeight="Bold"
                           FontSize="18"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Text="{Binding CarrierStatus}"
                           Foreground="{Binding CarrierStatusBrush}"
                           FontWeight="Bold"
                           FontSize="16"
                           VerticalAlignment="Center"/> 

                <!-- Mapping -->

                <TextBlock Grid.Row="2"
                           Text="Mapping"
                           FontWeight="Bold"
                           FontSize="18"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Text="{Binding MappingStatus}"
                           Foreground="{Binding MappingStatusBrush}"
                           FontWeight="Bold"
                           FontSize="16"
                           VerticalAlignment="Center"/> 

            </Grid>

        </GroupBox>

    </Grid>

</UserControl>