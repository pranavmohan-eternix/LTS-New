<UserControl x:Class="LTS.UI.Views.LoadPortManualControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>

        <Style TargetType="Button">

            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>

            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#D1D5DB"/>
                    <Setter Property="Foreground" Value="#6B7280"/>
                </Trigger>
            </Style.Triggers>

        </Style>

    </UserControl.Resources>

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.8*"/>
            <ColumnDefinition Width="1.4*"/>
        </Grid.ColumnDefinitions>

        <!-- Commands -->

        <GroupBox Header="Commands"
                  Grid.Column="0"
                  Margin="5">

            <StackPanel Margin="15">

                <Button Content="Dock"
                        Click="BtnDock_Click"
                        IsEnabled="{Binding CanDock}"/>

                <Button Content="Clamp"
                        Click="BtnClamp_Click"
                        IsEnabled="{Binding CanClamp}"/>

                <Button Content="Open Door"
                        Click="BtnOpenDoor_Click"
                        IsEnabled="{Binding CanOpenDoor}"/>

                <Button Content="Map Carrier"
                        Click="BtnMap_Click"
                        IsEnabled="{Binding CanMap}"/>

                <Button Content="Close Door"
                        Click="BtnCloseDoor_Click"
                        IsEnabled="{Binding CanCloseDoor}"/>

                <Button Content="Unclamp"
                        Click="BtnUnclamp_Click"
                        IsEnabled="{Binding CanUnclamp}"/>

                <Button Content="Undock"
                        Click="BtnUndock_Click"
                        IsEnabled="{Binding CanUndock}"/>

            </StackPanel>

        </GroupBox>

        <!-- Status -->

        <GroupBox Header="Status"
                  Grid.Column="1"
                  Margin="5">

            <Grid Margin="20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="170"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Load Port"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding Identifier}"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Row="1"
                           Text="Carrier"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Text="{Binding CarrierStatus}"
                           Foreground="{Binding CarrierStatusBrush}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Row="2"
                           Text="Dock"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Text="{Binding DockStatus}"
                           Foreground="{Binding DockStatusBrush}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Row="3"
                           Text="Clamp"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Row="3"
                           Grid.Column="1"
                           Text="{Binding ClampStatus}"
                           Foreground="{Binding ClampStatusBrush}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Row="4"
                           Text="Door"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Row="4"
                           Grid.Column="1"
                           Text="{Binding DoorStatus}"
                           Foreground="{Binding DoorStatusBrush}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Row="5"
                           Text="Mapping"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Row="5"
                           Grid.Column="1"
                           Text="{Binding MappingStatus}"
                           Foreground="{Binding MappingStatusBrush}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

            </Grid>

        </GroupBox>

    </Grid>

</UserControl>