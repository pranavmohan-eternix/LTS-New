<UserControl x:Class="LTS.UI.Views.TransferSystemManualControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>

        <Style TargetType="Button">

            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="15"/>

            <Style.Triggers>

                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#D1D5DB"/>
                    <Setter Property="Foreground" Value="#6B7280"/>
                </Trigger>

            </Style.Triggers>

        </Style>

    </UserControl.Resources>

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.8*"/>
            <ColumnDefinition Width="1.4*"/>
        </Grid.ColumnDefinitions>

        <!-- Commands -->

        <GroupBox Header="Commands"
                  Grid.Column="0"
                  Margin="5">

            <StackPanel Margin="15">

                <Button Content="Move to Load Port"
                        Click="BtnMoveToLoadPort_Click"
                        IsEnabled="{Binding CanMoveToLoadPort}"/>

                <Button Content="Pick"
                        Click="BtnPick_Click"
                        IsEnabled="{Binding CanPick}"/>

                <Button Content="Move to Chamber"
                        Click="BtnMoveToChamber_Click"
                        IsEnabled="{Binding CanMoveToChamber}"/>

                <Button Content="Place"
                        Click="BtnPlace_Click"
                        IsEnabled="{Binding CanPlace}"/>

                <Button Content="Move Home"
                        Click="BtnMoveHome_Click"
                        IsEnabled="{Binding CanMoveHome}"/>

            </StackPanel>

        </GroupBox>

        <!-- Status -->

        <GroupBox Header="Status"
                  Grid.Column="1"
                  Margin="5">

            <Grid Margin="25">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="170"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="45"/>
                    <RowDefinition Height="45"/>
                </Grid.RowDefinitions>

                <!-- Transfer -->

                <TextBlock Text="Transfer"
                           FontWeight="Bold"
                           FontSize="16"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding Identifier}"
                           FontSize="16"
                           VerticalAlignment="Center"/>

                <!-- Location -->

                <TextBlock Grid.Row="1"
                           Text="Location"
                           FontWeight="Bold"
                           FontSize="16"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Text="{Binding CurrentLocation}"
                           FontSize="16"
                           VerticalAlignment="Center"/>

                <!-- Holding -->

                <TextBlock Grid.Row="2"
                           Text="Holding"
                           FontWeight="Bold"
                           FontSize="16"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Text="{Binding HoldingStatus}"
                           Foreground="{Binding HoldingStatusBrush}"
                           FontWeight="Bold"
                           FontSize="16"
                           VerticalAlignment="Center"/>

            </Grid>

        </GroupBox>

    </Grid>

</UserControl>