<UserControl x:Class="LTS.UI.Views.ChamberManualControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>

        <Style TargetType="Button">

            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>

            <Style.Triggers>

                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#D1D5DB"/>
                    <Setter Property="Foreground" Value="#6B7280"/>
                </Trigger>

            </Style.Triggers>

        </Style>

    </UserControl.Resources>

    <Grid Margin="10">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.8*"/>
            <ColumnDefinition Width="1.4*"/>
        </Grid.ColumnDefinitions>

        <!-- Commands -->

        <GroupBox Header="Commands"
                  Grid.Column="0"
                  Margin="5">

            <StackPanel Margin="15"
                        VerticalAlignment="Top">

                <Button Content="Initialize"
                        Click="BtnInitialize_Click"
                        IsEnabled="{Binding CanInitialize}"/>

                <Button Content="Material Placed"
                        Click="BtnPlace_Click"
                        IsEnabled="{Binding CanPlaceMaterial}"/>

                <Button Content="Material Removed"
                        Click="BtnPick_Click"
                        IsEnabled="{Binding CanPickMaterial}"/>

                <Button Content="Run Recipe"
                        Click="BtnRunRecipe_Click"
                        IsEnabled="{Binding CanRunRecipe}"/>

            </StackPanel>

        </GroupBox>

        <!-- Status -->

        <GroupBox Header="Status"
                  Grid.Column="1"
                  Margin="5">

            <Grid Margin="25">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="55"/>
                    <RowDefinition Height="55"/>
                    <RowDefinition Height="55"/>
                    <RowDefinition Height="55"/>
                    <RowDefinition Height="55"/>
                </Grid.RowDefinitions>

                <!-- Chamber -->

                <TextBlock Text="Chamber"
                           FontWeight="Bold"
                           FontSize="16"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1"
                           Text="{Binding Identifier}"
                           FontSize="16"
                           VerticalAlignment="Center"/>

                <!-- State -->

                <TextBlock Grid.Row="1"
                           Text="State"
                           FontWeight="Bold"
                           FontSize="16"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Text="{Binding ProcessState}"
                           Foreground="{Binding ProcessStateBrush}"
                           FontWeight="Bold"
                           FontSize="16"
                           VerticalAlignment="Center"/>

                <!-- Material -->

                <TextBlock Grid.Row="2"
                           Text="Material"
                           FontWeight="Bold"
                           FontSize="16"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Text="{Binding MaterialPresence}"
                           FontSize="16"
                           VerticalAlignment="Center"/>

                <!-- Duration -->

                <TextBlock Grid.Row="3"
                           Text="Duration"
                           FontWeight="Bold"
                           FontSize="16"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Row="3"
                           Grid.Column="1"
                           Text="{Binding ProcessDuration}"
                           FontSize="16"
                           VerticalAlignment="Center"/>

                <!-- Recipe -->

                <TextBlock Grid.Row="4"
                           Text="Recipe"
                           FontWeight="Bold"
                           FontSize="16"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Row="4"
                           Grid.Column="1"
                           Text="{Binding SelectedRecipe}"
                           FontSize="16"
                           VerticalAlignment="Center"/>

            </Grid>

        </GroupBox>

    </Grid>

</UserControl>